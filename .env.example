# --- Database (required) --------------------------------------------------
DATABASE_URL=mysql://user:password@localhost:3306/medcare_clinic

# --- App ---------------------------------------------------------------
NODE_ENV=development
PORT=3000

# Random string, 32+ characters. Sessions are signed with this — generate
# one with `openssl rand -base64 32`. Required in production (the app
# refuses to start without it); a weak dev-only default is used locally.
SESSION_SECRET=

# --- One-time admin seeding (server/scripts/seed.ts) ------------------
# Only read once, at seed time, to create the first staff account. The
# password is hashed immediately and never stored or logged in plaintext —
# these two vars don't need to stay in .env after you've run `npm run db:seed`.
ADMIN_EMAIL=admin@yourclinic.example
ADMIN_PASSWORD=change-this-to-a-real-password

# --- Email (optional) ---------------------------------------------------
# Leave all of these blank to skip real email sending — the app logs
# notification content to the console instead, and booking always still
# succeeds either way.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
CLINIC_FROM_EMAIL=no-reply@yourclinic.example
NOTIFY_OWNER_EMAIL=

# --- SMS (optional) ------------------------------------------------------
# Sparrow SMS (sparrowsms.com) — leave blank to skip, same graceful
# fallback as email: booking still succeeds, this just logs instead.
# SPARROW_SMS_SENDER_ID is the NTA-approved sender ID from your dashboard,
# not a phone number.
SPARROW_SMS_TOKEN=
SPARROW_SMS_SENDER_ID=
